# Outsourced Technologies - Environment Variables
# Copy this to .env and fill in your values

# Application Environment (use 'production' for live sites)
APP_ENV=development

# Database Configuration
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=outsourced_tech
DB_USER=root
DB_PASS=

# Base URL
BASE_URL=http://192.168.1.143/outsourced/public/

# CORS — set to your actual frontend domain in production (e.g. https://yourdomain.com)
ALLOWED_ORIGIN=http://192.168.1.143

# M-Pesa Configuration (get these from https://developer.safaricom.co.ke)
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=http://192.168.1.143/outsourced/api/mpesa/callback.php

# Backup endpoint secret key — change this to a long random string
BACKUP_SECRET_KEY=change-me-to-a-long-random-string

# Cron job secret key
CRON_SECRET_KEY=test123

# Admin email for notifications
ADMIN_EMAIL=admin@outsourcedtechnologies.co.ke

# Company Info
COMPANY_NAME="Outsourced Technologies"
COMPANY_ADDRESS="Mlolongo, Kenya"
COMPANY_PHONE="+254 700 000 000"
COMPANY_EMAIL=info@outsourcedtechnologies.co.ke

# Email Configuration (SMTP)
# IMPORTANT: For Gmail, you need an App Password, not your regular password
# See instructions below to create one: https://support.google.com/accounts/answer/185833
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=gordi14062002@gmail.com
MAIL_PASSWORD="hrkq kkfc gdfx zgey"
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=gordi14062002@gmail.com
MAIL_FROM_NAME="Outsourced Technologies"
